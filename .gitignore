# Learn more about .gitignore:
#     https://www.atlassian.com/git/tutorials/saving-changes/gitignore

# Log files
*.log


# Generated by MacOS
.DS_Store

# Generated by Windows
Thumbs.db

# Applications
*.app
*.exe
*.war

# Large media files
*.mp4
*.tiff
*.avi
*.flv
*.mov
*.wmv


# Temporary files from C++ compilation
*.d
*.o

# Default C++ test executables (make/makefile.common uses TARGET ?= test)
cpp/**/test
cpp/**/test.exe

# Tracker executable (cpp/tracker/makefile TARGET := tracker)
cpp/**/tracker/tracker
